package com.string;

public class CountCharactersWithoutSpaces {

	public static void main(String[] args) {
		String str =  "Java is Easy";
		int countchar=0;
		for(int i=0;i<str.length();i++) {
			char ch = str.charAt(i);
			if(ch !=' ') {
				countchar++;
			}
		}
		System.out.println("Count char : " + countchar);
	}
}
