package com.string;

public class RemoveDuplicateCharacters {

    public static void main(String[] args) {

        String s = "success";
        String result = "";

        for (int i = 0; i < s.length(); i++) {

            boolean isDuplicate = false;

            for (int j = 0; j < i; j++) {

                if (s.charAt(i) == s.charAt(j)) {
                    isDuplicate = true;
                    break;
                }
            }

            if (!isDuplicate) {
                result += s.charAt(i);
            }
        }

        System.out.println("After removing duplicates: " + result);
    }
}
