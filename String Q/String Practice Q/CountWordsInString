package com.string;

public class CountWordsInString {

	public static void main(String[] args) {
		String str = " Java is Easy";
		int countWord=1;
		for(int i=0;i<str.length();i++) {
//			char ch = str.charAt(i);
			if(str.charAt(i) == ' ') {
				countWord++;
			}
		}
		System.out.println("Count Total Words : " +countWord );
	}
}
