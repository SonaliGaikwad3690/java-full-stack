package com.string;

public class DigitsCharacter {

	public static void main(String[] args) {
		
		String str = "Java1234";
		String characters = "";
		String digit="";
		for(int i=0;i<str.length();i++) {
			char ch = str.charAt(i);
			if(Character.isDigit(ch)) {
				digit += ch;
			}else {
				characters += ch;
			}
		}
		System.out.println("Digit : " + digit );
		System.out.println("Char : " + characters);
	

	}
}
