package com.stringPracticeQ;

public class Q2 {

	public static void main(String[] args) {
		String str = "madam";
		String rev="";
		for(int i=str.length()-1 ;i>=0;i--) {
			rev=rev + str.charAt(i);
		}if(str.equals(rev)) {
			System.out.println("Yes...!");
		}else {
			System.out.println("Not....!");
		}
	}
}
