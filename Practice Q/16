
public class Q119 {

	public static void main(String[] args) {
		int num=121;
		int org=num;
		int i =1;
		int rem=0;
		int rev=0;
		while(i<=num) {
			rem =num%10;
			rev =rev*10+rem;
			num=num/10;
		}
		if(org==rev) {
			System.out.println("Yes...!");
		}else {
			System.out.println("No...!");
		}
	}
}
