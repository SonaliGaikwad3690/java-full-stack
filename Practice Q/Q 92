public class Q92 {

	public static void main(String[] args) {
//		check prime number
		int num = 11;
		int count = 0;
		for(int i =1;i<=num;i++) {
			if(num%i==0) {
				count++;
			}
		}
		if(count==2) {
			System.out.println(num + " is Prime Number");
		}else {
			System.err.println(num + " is not A Prime Number");
		}
	}
}
