
public class Q108 {

	public static void main(String[] args) {
		String str = "mam";
		String rev = "";
		for(int i=str.length()-1;i>=0;i--) {
			rev += str.charAt(i);
		}if(str.equals(rev)) {
			System.out.println("Yes this is Palindrome String");
		}else {
			System.out.println("Not this is Not a Palindrome String");

		}
	}
}
