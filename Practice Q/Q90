
public class Q90 {

	public static void main(String[] args) {
		 int num =232;
		 int rev = 0;
		 int rem = 0;
		 int org = num ;
		 while(num>=1) {
			 rem = num%10;
			 rev = rev*10+ rem;
			 num = num/10;
		 }if(org==rev) {
			 System.out.println("Palindrome Number = " + rev);
		 }else {
			 System.err.println("Not Palindrom");
		 }
	}
}
