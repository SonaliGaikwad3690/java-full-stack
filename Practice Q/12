package com.ArrayPracticeQA;

public class Q131 {

	public static void main(String[] args) {
		int arr[] = { 10, 20, 30, 20, 40 };
		
	
		for(int i=0;i<arr.length;i++) {
			boolean isDuplicate = false;
			for(int j=0;j<arr.length;j++) {
				if( i !=j && arr[i]==arr[j]) {
					 isDuplicate=true;
					 break;
				}
			}
		if(!isDuplicate) {
			System.out.println(arr[i]);
		  }
		}
	}
}
