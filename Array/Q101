package com.ArrayPracticeQA;

public class Q101 {

	public static void main(String[] args) {
		int arr[][]= { {9,2,3}, 
                {6,2,3},
                {1,2,1} };
		int evenCount=0;
		int oddCount=0;
		for(int i=0;i<arr.length;i++) {
			for(int j=0;j<arr[i].length;j++) {
				if(arr[i][j]%2==0) {
					evenCount++;
				}else {
					oddCount++;
				}
			}
		}
		System.out.println("Even Count : " + evenCount);
		System.out.println("Odd count : " + oddCount);
	}
}
