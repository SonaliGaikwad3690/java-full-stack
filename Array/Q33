package com.ArrayPracticeQA;

public class Q33 {

	public static void main(String[] args) {
		int num =11;
		int count=0;
		for(int i=0; i<=5;i++) {
			if(num%i==0) {
				count++;
			}
		    } if(count==2) {
				System.out.println(num + " is a Prime Number......!");
			}else {
				System.out.println(num + " is Not A Prime Numebr");
			
		}
	}
}
