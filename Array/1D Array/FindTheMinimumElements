package com.Array1D;
//Write a program to find the minimum element in a 1D array.

public class MinElements {

	public static void main(String[] args) {
		int arr []= {2 ,4 ,5 ,8,6 };
		int min = arr[0];
		for(int i = 0;i<arr.length;i++) {
			if(arr[i]<min) {
				min = arr[i];
			}
		}
		System.out.println("Mininum Value Of Given Elements = " + min);
	}
}
