package com.string;

public class ReplaceSpace {

	public static void main(String[] args) {
		String s = "Jav is Easy";
		String result ="";
		for(int i=0;i<s.length();i++) {
			char ch = s.charAt(i);
			if(ch ==' ') {
				result+='@';
			}else{
				result+=ch;
			}
		}
		System.out.println(result);
	}
}
