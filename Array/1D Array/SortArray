package com.string;

public class SortArray {

	public static void main(String[] args) {
		int arr[]= { 2,3,6,5,4};
		
		for(int i=0;i<arr.length;i++) {
			for(int j=i+1;j<arr.length;j++) {
				if(arr[i] > arr[j]) {
					int temp = arr[j];
					arr[j] = arr[i];
					arr[i]=temp;
				}
			}
		}
		System.out.print("Sorted Array : ");
		for (int i : arr) {
			System.out.print(i + " ");
		}
	}
}
