package com.Array1D;
//Write a program to Sum even and odd numbers in a 1D array.
public class SumOfEvenOdd {

	public static void main(String[] args) {
		int arr[] = { 20, 44, 15,3, 28, 66 };
		int sumOfEven = 0;
		int sumOfOdd= 0;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] % 2 == 0) {
				System.out.println(arr[i]);
				sumOfEven = sumOfEven + arr[i];
			} else {
				sumOfOdd = sumOfOdd + arr[i];
			}
		}
		System.out.println("Sum Of Even Number = " + sumOfEven);
		System.out.println("Sum Of Odd Number = " + sumOfOdd);
	
	}
}
