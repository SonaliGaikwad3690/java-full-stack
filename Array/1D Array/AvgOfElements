package com.Array1D;
//Write a program to find the average of elements in a 1D array.
public class AvgOfElements {

	public static void main(String[] args) {
		int arr []= {20,40,30,10,50};
		int avg = 0;
		int sum =0;
		for(int i=0;i<arr.length;i++) {
			sum = sum + arr[i];
		}
		avg = sum /arr.length;
		System.out.println("sum Of the Elemnents = " + sum);
		System.out.println("Avargae od f The Elements = " + avg);
	}
}
