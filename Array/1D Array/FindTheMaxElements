package com.Array1D;
//Write a program to find the maximum element in a 1D array.
public class MaxElements {

	public static void main(String[] args) {
		int arr []= {2 ,4 ,5 ,8,6 };
		int max = arr[0];
		for(int i = 0;i<arr.length;i++) {
			if(arr[i]>max) {
				max = arr[i];
			}
		}
		System.out.println(max);
	}
}
