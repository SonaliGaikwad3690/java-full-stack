package com.ArrayPracticeQA;

public class Q84 {

	public static void main(String[] args) {
		String str ="mam";
		String result ="";
        for(int i=str.length()-1;i>=0;i--) {
        	   char ch= str.charAt(i);
        	   result += ch;
        }
		if(str.contains(result)) {
			System.out.println("Yes Palindrome");
		}else {
			System.out.println("No");
		}
	}
}
