public class ArrayExample3 {
    public static void main(String[] args) {

        int arr[] = {10, 25, 8, 90, 45};
        int max = arr[0];

        for(int i = 0; i < arr.length; i++) {
            if(arr[i] > max) {
                max = arr[i];
            }
        }

        System.out.println("Largest Number = " + max);
    }
}
