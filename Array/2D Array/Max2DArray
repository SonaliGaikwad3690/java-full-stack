package com.Array2D;

public class Max2DArray {

	public static void main(String[] args) {
		int arr[][]= {{10,20,30},{40,50,60} ,{70,80,90}};
		int max= arr[0][0];
		 for(int i=0;i<arr.length;i++) {
			 for(int j=0;j<arr.length;j++) {
				 if(arr[i][j]>max) {
				 max = arr[i][j];
				 }
			 }
		 }
		 System.out.println("Max value = " + max);
	}
}
