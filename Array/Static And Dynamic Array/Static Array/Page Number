package com.Array;

public class PageNumber {

	public static void main(String[] args) {
		short []pageNum = {12,36,89,1,32,50 };
		System.out.println("Page Number...!");
		for(int i =0; i<pageNum.length;i++) {
			System.out.println("Rs = " + pageNum[i] );
		}
		System.out.println("Total Length of Page Number : " + pageNum.length);
	}
}
