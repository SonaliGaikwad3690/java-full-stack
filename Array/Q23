package com.ArrayPracticeQA;

public class Q23 {

	public static void main(String[] args) {
		String str = "mam";
		String result ="";
		 for(int i=str.length()-1;i>=0;i--) {
			 result +=str.charAt(i);;
		 }if(str.equals(result)) {
			 System.out.println(str + " is a Palindrome String...!");
		 }else {
			 System.err.println(str + " is Not a Palindrome String...!");
		 }
	}
}
