package com.ArrayPracticeQA;

import java.lang.reflect.Array;

public class Q9 {

	public static void main(String[] args) {
		int arr[]= {12, 23,45,50};
		int largest = arr[0];
		int smallest = arr[0];
		for(int i =0;i<arr.length;i++) {
			if(arr[i] > largest) {
				largest = arr[i];
			}else if(arr[i] < smallest) {
				smallest = arr[i];
			}
		}System.out.println(largest);
		System.out.println(smallest);
	}
}
